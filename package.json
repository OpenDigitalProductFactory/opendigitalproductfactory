{
  "name": "dpf",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "test": "pnpm --filter web test && pnpm --filter @dpf/db test && pnpm --filter mobile test",
    "test:e2e": "playwright test",
    "test:e2e:demo": "playwright test -c playwright-demo.config.ts",
    "typecheck": "pnpm --filter web typecheck && pnpm --filter @dpf/db typecheck && pnpm --filter @dpf/types typecheck && pnpm --filter @dpf/validators typecheck && pnpm --filter @dpf/api-client typecheck && pnpm --filter mobile typecheck",
    "db:generate": "pnpm --filter @dpf/db generate",
    "db:migrate": "pnpm --filter @dpf/db migrate",
    "db:seed": "pnpm --filter @dpf/db seed",
    "db:studio": "pnpm --filter @dpf/db studio",
    "graph:init": "pnpm --filter @dpf/db exec tsx scripts/init-neo4j.ts",
    "test:endpoints": "tsx scripts/test-endpoints.ts",
    "docs:tak": "node docs/architecture/generate-tak-docx.mjs"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19",
      "@hono/node-server": "1.19.13",
      "lodash": "4.18.0",
      "@tootallnate/once": "3.0.1",
      "@xmldom/xmldom": "0.8.13",
      "dompurify": "3.4.0",
      "node-forge": "1.4.0"
    },
    "onlyBuiltDependencies": [
      "msw",
      "sharp"
    ]
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@playwright/test": "^1.59.1",
    "docx": "^9.6.1"
  }
}
