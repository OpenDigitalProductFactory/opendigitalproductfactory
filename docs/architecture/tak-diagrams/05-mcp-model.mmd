        CLIENT["MCP Client\nNamespace router"]
        AUTH_CHECK["TAK Authority\nCheck"]

        SERVER --> AUTH_CHECK --> TOOLS
        CLIENT --> AUTH_CHECK
    end

    subgraph EXTERNAL_SERVERS["External MCP Servers"]
        SLACK["slack:\nsend_message"]
        JIRA["jira:\ncreate_issue"]
