{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "DPF: Shared Workspace Dev Server",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "pnpm --filter web dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "DPF: Production Build",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "pnpm --filter @dpf/db exec prisma generate && pnpm --filter web build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "DPF: Type Check",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "pnpm --filter web exec tsc --noEmit"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "DPF: Shared Workspace Infrastructure",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "docker compose up -d postgres neo4j qdrant portal-init sandbox"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "detail": "Start databases + validation services for shared-workspace development"
    },
    {
      "label": "DPF: Start Production Runtime",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "docker compose up -d"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "detail": "Start full Docker stack including portal"
    },
    {
      "label": "DPF: Stop Production Runtime",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "docker compose down"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "DPF: Restart Production Runtime",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "docker compose down && docker compose up -d"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "DPF: Production Runtime Logs",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "docker compose logs -f --tail 50"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "DPF: Rebuild Production Runtime",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "docker compose build portal portal-init && docker compose up -d portal-init && docker compose up -d portal"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "problemMatcher": [],
      "detail": "Rebuild the production runtime image from source and restart it (includes migrations)"
    },
    {
      "label": "DPF: Rebuild All",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "docker compose build && docker compose up -d"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "problemMatcher": [],
      "detail": "Rebuild all images and restart full stack"
    },
    {
      "label": "DPF: Release Minor",
      "type": "shell",
      "command": "powershell",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/dpf-release.ps1", "minor"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "detail": "Pull latest main, bump minor version (v0.85.0 -> v0.86.0), tag and push"
    },
    {
      "label": "DPF: Release Patch",
      "type": "shell",
      "command": "powershell",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/dpf-release.ps1", "patch"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "detail": "Pull latest main, bump patch version (v0.85.0 -> v0.85.1), tag and push"
    },
    {
      "label": "DPF: Release Major",
      "type": "shell",
      "command": "powershell",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/dpf-release.ps1", "major"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "detail": "Pull latest main, bump major version (v0.85.0 -> v1.0.0), tag and push"
    }
  ]
}
