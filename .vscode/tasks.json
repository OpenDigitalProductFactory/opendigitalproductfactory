{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "DPF: Dev Server",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "pnpm --filter web dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "DPF: Production Build",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "pnpm --filter @dpf/db exec prisma generate && pnpm --filter web build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "DPF: Type Check",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "pnpm --filter web exec tsc --noEmit"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "DPF: Publish Release",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "echo Enter version tag (e.g. v0.2.0): && set /p TAG= && git tag %TAG% && git push origin main && git push origin %TAG% && echo Published %TAG% to GHCR"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
