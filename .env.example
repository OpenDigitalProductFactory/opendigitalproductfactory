# App-level environment — copy to:
#   apps/web/.env.local    (Next.js + local host-side Prisma commands)
#
# Optional legacy fallback:
#   packages/db/.env       (only if you need a package-local Prisma override)
#
# For Docker Compose container config, see .env.docker.example instead.

# PostgreSQL
DATABASE_URL="postgresql://dpf:dpf_dev@localhost:5432/dpf"

# Neo4j
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="dpf_dev_password"

# Auth.js
AUTH_SECRET="<generate with: openssl rand -base64 32>"
AUTH_TRUST_HOST=true

# Credential encryption (AES-256-GCM, 32 bytes hex)
# Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY="<generate with: openssl rand -hex 32>"

# Anthropic (Agent co-worker)
ANTHROPIC_API_KEY="<your key>"

# Branding logo object storage (S3-compatible, R2, etc.)
BRANDING_LOGO_S3_BUCKET="<bucket name>"
BRANDING_LOGO_S3_REGION="us-east-1"
BRANDING_LOGO_S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
BRANDING_LOGO_S3_FORCE_PATH_STYLE="1"
BRANDING_LOGO_AWS_ACCESS_KEY_ID="<object storage access key id>"
BRANDING_LOGO_AWS_SECRET_ACCESS_KEY="<object storage secret>"
BRANDING_LOGO_PUBLIC_URL_PREFIX="https://cdn.example.com/branding"
BRANDING_LOGO_ALLOW_DATA_URL_FALLBACK="0"

# ── Social Auth (Google / Apple sign-in for customers) ───
# Set ENABLE_SOCIAL_AUTH to "true" to activate OAuth providers
ENABLE_SOCIAL_AUTH=false
# Exposed to client for conditional UI rendering
NEXT_PUBLIC_ENABLE_SOCIAL_AUTH=false
# Google OAuth 2.0 credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="<your Google client ID>"
GOOGLE_CLIENT_SECRET="<your Google client secret>"
# Apple Sign In credentials (https://developer.apple.com/account/resources/identifiers)
APPLE_CLIENT_ID="<your Apple service ID>"
APPLE_CLIENT_SECRET="<your Apple client secret>"
APPLE_TEAM_ID="<your Apple team ID>"
APPLE_KEY_ID="<your Apple key ID>"

# ── Inngest (durable execution engine) ───────────────────
INNGEST_EVENT_KEY=deadbeefcafebabe
INNGEST_SIGNING_KEY=abcdef0123456789
INNGEST_BASE_URL=http://localhost:8288
INNGEST_DEV=1

# ── Local LLM Inference (Docker Model Runner) ────────────
# Docker Model Runner is built into Docker Desktop 4.40+.
# Pull models:  docker model pull ai/llama3.2:1B-Q8_0
# List models:  docker model list
# Default URL works automatically inside Docker Compose containers.
# Override only for custom setups (e.g., external Ollama):
# LLM_BASE_URL=http://model-runner.docker.internal/v1
