# Copy to .env.local in apps/web and to packages/db/.env

# PostgreSQL
DATABASE_URL="postgresql://dpf:dpf_dev@localhost:5432/dpf"

# Neo4j
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="dpf_dev_password"

# Auth.js
AUTH_SECRET="<generate with: openssl rand -base64 32>"
AUTH_URL="http://localhost:3000"

# Anthropic (Agent co-worker)
ANTHROPIC_API_KEY="<your key>"
