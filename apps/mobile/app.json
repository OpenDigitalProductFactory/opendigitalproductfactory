{
  "expo": {
    "name": "DPF Mobile",
    "slug": "dpf-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "dpf-mobile",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      "expo-location",
      "expo-notifications",
      "expo-sqlite"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dpf.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e1e2e"
      },
      "package": "com.dpf.mobile"
    }
  }
}
