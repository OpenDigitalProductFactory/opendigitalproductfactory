  productId       String? // FK to DigitalProduct (optional — ad-hoc lines)
  description     String
  quantity        Int      @default(1)
  unitPrice       Decimal
  discountPercent Decimal  @default(0)
  taxPercent      Decimal  @default(0)
  lineTotal       Decimal // unitPrice * quantity * (1 - discountPercent/100)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  quote   Quote           @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product DigitalProduct? @relation(fields: [productId], references: [id])

  @@index([quoteId])
}

