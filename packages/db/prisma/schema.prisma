// Polymorphic credentials for enterprise integrations (ADP, QuickBooks, Plaid, Workday, …).
// Distinct from CredentialEntry, which is OAuth-shaped for LLM providers.
// fieldsEnc holds a JSON blob encrypted via credential-crypto.ts encryptJson.
model IntegrationCredential {
  id            String    @id @default(cuid())
  integrationId String    @unique
  provider      String
  status        String    @default("unconfigured")
  fieldsEnc     String    @db.Text
  tokenCacheEnc String?   @db.Text
  lastTestedAt  DateTime?
  lastErrorAt   DateTime?
  lastErrorMsg  String?
  certExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([provider, status])
}

// Call-level audit log for every enterprise-integration MCP tool invocation.
// Distinct from ComplianceAuditLog (entity-diff focused) and AgentActionProposal
// (write-proposal focused). Reusable across ADP, QuickBooks, Plaid, Workday.
// argsHash is sha256 of canonicalized args — raw args are never stored.
model IntegrationToolCallLog {
  id           String   @id @default(cuid())
  calledAt     DateTime @default(now())
  integration  String
  coworkerId   String
  userId       String?
  toolName     String
  argsHash     String
  responseKind String
  resultCount  Int?
  durationMs   Int
  errorCode    String?
  errorMessage String?

  @@index([calledAt])
  @@index([integration, calledAt])
  @@index([coworkerId, calledAt])
  @@index([toolName, calledAt])
}

