// EP-INF-012: Per-agent model assignment configuration (admin-overridable)
model AgentModelConfig {
  agentId              String   @id // e.g. "build-specialist", "coo"
  minimumTier          String   @default("adequate") // "frontier" | "strong" | "adequate" | "basic"
  pinnedProviderId     String?
  pinnedModelId        String?
  budgetClass          String   @default("balanced") // "minimize_cost" | "balanced" | "quality_first"
  // EP-AGENT-CAP-002: Hard capability floor — model must satisfy ALL declared capabilities.
  // Null = system default { "toolUse": true }.
  // {} = passive agent (no capability floor — rare, must be explicit).
  minimumCapabilities  Json?
  // EP-AGENT-CAP-002: Minimum context window tokens for RAG/knowledge retrieval.
  // Null = system default 16000.
  minimumContextTokens Int?
  configuredAt         DateTime @default(now())
  configuredById       String?
  configuredBy         User?    @relation("AgentModelConfiguredBy", fields: [configuredById], references: [id])
}

// EP-SKILL-001: AI Coworker Skills Marketplace
model SkillDefinition {
  id             String   @id @default(cuid())
  skillId        String   @unique // e.g. "code-runner", "pr-summary"
  name           String
  description    String
  version        String   @default("1.0.0")
  sourceType     String // "marketplace" | "github" | "internal" | "community"
  sourceUrl      String?
  sourceRegistry String? // "skillsmp" | "skillsllm" | "anthropics" | "internal"
  skillMdContent String // Full SKILL.md content
  category       String // "ai-agents" | "mcp-servers" | "cli-tools" | "portfolio" | "operations" | "universal" | etc.
  tags           String[] @default([])
  author         String?
  license        String?
  riskBand       String   @default("low") // "low" | "medium" | "high" | "critical"
  status         String   @default("discovered") // "discovered" | "evaluated" | "approved" | "installed" | "active" | "deprecated"

  // --- SKILL.md pattern fields (Phase 2 enrichment) ---
  triggerPattern      String? // regex/keywords for auto-suggestion (Anthropic's description-as-trigger)
  userInvocable       Boolean  @default(true) // can humans invoke directly?
  agentInvocable      Boolean  @default(true) // can other coworkers invoke?
  allowedTools        String[] @default([]) // tools this skill may use
  composesFrom        String[] @default([]) // other skillIds this skill builds on
  contextRequirements String[] @default([]) // what context/data the skill needs
  capability          String? // permission gate (e.g. "view_portfolio") — null = ungated
  taskType            String   @default("conversation") // "conversation" | "code_generation" | "analysis"

  evaluationId String?
  installedAt  DateTime?
  lastTestedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  evaluation  ToolEvaluation?   @relation(fields: [evaluationId], references: [id])
  assignments SkillAssignment[]
  metrics     SkillMetric[]

  @@index([status])
  @@index([category])
  @@index([sourceType])
}

model SkillAssignment {
  id         String   @id @default(cuid())
  // Business skill identifier (e.g. "code-runner"), references SkillDefinition.skillId.
  // Not the cuid primary key — the column name and every caller treat this as the
  // stable business identifier so it stays legible in logs and cross-install exports.
  skillId    String
  agentId    String // Which coworker gets this skill
  priority   Int      @default(0) // Higher = loaded first
  enabled    Boolean  @default(true)
  assignedBy String // User who approved
  assignedAt DateTime @default(now())

  skill SkillDefinition @relation(fields: [skillId], references: [skillId], onDelete: Cascade)

  @@unique([skillId, agentId])
  @@index([agentId])
}

model SkillMetric {
  id              String   @id @default(cuid())
  skillId         String // Business id; see SkillAssignment.skillId comment
  agentId         String
  period          String // "2026-W13", "2026-03"
  invocationCount Int      @default(0)
  successCount    Int      @default(0)
  userRating      Float? // 1-5 average
  avgLatencyMs    Int?
  feedbackNotes   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  skill SkillDefinition @relation(fields: [skillId], references: [skillId], onDelete: Cascade)

  @@unique([skillId, agentId, period])
  @@index([skillId])
}

// ─── EP-DELEG-001: Delegation Chain (Authority Propagation & Chain of Custody) ─

model DelegationChain {
  id              String    @id @default(cuid())
  chainId         String // UUID grouping all links in one delegation flow
  depth           Int // 0 = origin, 1 = first delegate, etc.
  fromAgentId     String // delegating coworker
  toAgentId       String // receiving coworker
  skillId         String? // which skill triggered delegation
  authorityScope  String[] // capabilities propagated from origin caller
  originUserId    String // human who started the chain
  originAuthority String[] // original user's granted capabilities
  status          String    @default("active") // "active" | "completed" | "failed" | "blocked"
  reason          String? // why delegation was made or blocked
  parentLinkId    String? // previous link in chain (null for origin)
  startedAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([chainId])
  @@index([fromAgentId])
  @@index([toAgentId])
  @@index([status])
}

// ─── EP-KM-001: Knowledge Management ──────────────────────────────────────────

model KnowledgeArticle {
  id                 String                      @id @default(cuid())
  articleId          String                      @unique // Human-readable: KA-001, KA-002...
  title              String
  body               String                      @db.Text
  category           String // process | policy | decision | how-to | reference | troubleshooting | runbook
  status             String                      @default("draft") // draft | published | review-needed | archived
  visibility         String                      @default("internal") // internal | team | public
  authorId           String?
  authorAgentId      String?
  reviewIntervalDays Int                         @default(90)
  lastReviewedAt     DateTime?
  valueStreams       String[]                    @default([])
  tags               String[]                    @default([])
  abstract           String? // EP-INF-UTIL-001: one-line abstract generated by utility tier
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  author             User?                       @relation("KnowledgeArticleAuthor", fields: [authorId], references: [id])
  authorAgent        Agent?                      @relation("KnowledgeArticleAgentAuthor", fields: [authorAgentId], references: [id])
  revisions          KnowledgeArticleRevision[]
