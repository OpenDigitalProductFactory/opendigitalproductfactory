  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  account            CustomerAccount             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  primaryAddress     Address?                    @relation(fields: [primaryAddressId], references: [id])
  configurationItems CustomerConfigurationItem[]
  nodes              CustomerSiteNode[]

  @@index([accountId])
  @@index([primaryAddressId])
  @@index([status])
  @@index([siteType])
}

model CustomerConfigurationItem {
  id                    String          @id @default(cuid())
  customerCiId          String          @unique
  accountId             String
  siteId                String?
  name                  String
  ciType                String
  status                String          @default("active")
  technologySourceType  String          @default("commercial")
  supportModel          String?
  manufacturer          String?
  vendorName            String?
  productName           String?
  edition               String?
  productModel          String?
  serialNumber          String?
  assetTag              String?
  observedVersion       String?
  normalizedVersion     String?
  installDate           DateTime?
  purchaseDate          DateTime?
  firstSeenAt           DateTime?
  warrantyStartAt       DateTime?
  warrantyEndAt         DateTime?
  endOfSaleAt           DateTime?
  endOfSupportAt        DateTime?
  endOfLifeAt           DateTime?
  renewalDate           DateTime?
  lifecycleStatus       String          @default("unknown")
  supportStatus         String          @default("unknown")
  recommendedAction     String?
  lifecycleConfidence   Float?
  lastLifecycleReviewAt DateTime?
  nextLifecycleReviewAt DateTime?
  lifecycleEvidence     Json?
  licenseQuantity       Decimal?        @db.Decimal(12, 2)
  billingCadence        String?
  customerChargeModel   String?
  unitCost              Decimal?        @db.Decimal(12, 2)
  customerUnitPrice     Decimal?        @db.Decimal(12, 2)
