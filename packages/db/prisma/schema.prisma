  @@index([siteId])
  @@index([ciType])
  @@index([status])
  @@index([technologySourceType])
}

model CustomerSiteNode {
  id           String             @id @default(cuid())
  nodeId       String             @unique
  siteId       String
  parentNodeId String?
  name         String
  nodeType     String             @default("area")
  status       String             @default("active")
  notes        String?
