model PhaseHandoff {
  id                String   @id @default(cuid())
  buildId           String
  fromPhase         String
  toPhase           String
  fromAgentId       String
  toAgentId         String
  summary           String /// 2-3 sentence plain language summary of what the phase accomplished
  decisionsMade     String[] @default([])
  openIssues        String[] @default([])
  userPreferences   String[] @default([])
  evidenceFields    String[] @default([]) /// Which evidence fields were populated (e.g., ["designDoc", "designReview"])
  evidenceDigest    Json     @default("{}") /// One-line summary per evidence field
  gateResult        Json     @default("{}") /// The gate check that allowed advancement
  tokenBudgetUsed   Int      @default(0)
  toolsUsed         String[] @default([])
  iterationCount    Int      @default(0)
