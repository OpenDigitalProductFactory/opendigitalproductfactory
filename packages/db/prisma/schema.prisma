  profileConfidence    String    @default("low") // "low" | "medium" | "high"
  lastEvaluatedAt      DateTime?
  agent                Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, taskType])
  @@index([agentId])
}

model FeatureDegradationMapping {
  id              String  @id @default(cuid())
  agentId         String
  featureRoute    String // e.g. "/build", "/portfolio"
  featureName     String // e.g. "Build Studio code generation"
  requiredTier    String // "frontier" | "strong" | "adequate" | "basic"
  degradationMode String // "disabled" | "reduced" | "fallback_agent" | "manual_only"
  fallbackAgentId String? // Agent that takes over when degraded
  userMessage     String? // Shown to user when degraded
  agent           Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, featureRoute])
  @@index([agentId])
}

model AgentPromptContext {
  id                String   @id @default(cuid())
  agentId           String   @unique
  perspective       String? // Scott Page: how agent frames problems
  heuristics        String? // How agent searches for solutions
  interpretiveModel String? // What agent optimizes for
  domainTools       String[] @default([]) // Tool names available to this domain
  agent             Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AuthorizationDecisionLog {
