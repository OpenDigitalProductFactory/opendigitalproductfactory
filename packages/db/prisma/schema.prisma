model KnowledgeArticlePortfolio {
  articleId   String
  portfolioId String
  article     KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  portfolio   Portfolio        @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@id([articleId, portfolioId])
}

// ─── Value Stream Team Architecture (EP-VST-001) ─────────────────────────────
// Spec: docs/superpowers/specs/2026-04-03-value-stream-team-architecture-design.md

model ValueStreamTeam {
  id                  String                @id @default(cuid())
  name                String
  valueStream         String // IT4IT value stream slug: evaluate|explore|integrate|deploy|release|consume|operate
  teamPattern         String // specialist-dispatch|review-board|pair|swarm|pipeline
  coordinationPattern Json // CoordinationPattern structure
  eaProcessId         String? // Link to EaElement (bpmn_process)
  eaViewId            String? // Link to EaView
  portfolioId         String?
  portfolio           Portfolio?            @relation(fields: [portfolioId], references: [id])
  roles               ValueStreamTeamRole[]
  hitlGates           ValueStreamHitlGate[]
  queues              WorkQueue[]
  workItems           WorkItem[]
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([portfolioId])
  @@index([valueStream])
}

model ValueStreamTeamRole {
  id                String          @id @default(cuid())
  teamId            String
  team              ValueStreamTeam @relation(fields: [teamId], references: [id])
  roleName          String
  workerType        String // ai-agent|human|either
  agentId           String? // References Agent.id (cuid PK), not Agent.agentId
  agent             Agent?          @relation(fields: [agentId], references: [id])
  humanRoleId       String? // PlatformRole reference
  perspective       String? // Diversity of Thought: how this role frames problems
  heuristics        String? // Diversity of Thought: strategies for finding solutions
  interpretiveModel String? // Diversity of Thought: what "good" means to this role
  priority          Int             @default(0)
  grantScope        String[]        @default([]) // AgentToolGrant keys resolved to tool names at dispatch
  modelTier         String? // frontier|strong|adequate|basic
  bpmnLaneId        String? // Link to EaElement (bpmn_lane)
  maxRetries        Int             @default(2)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([teamId])
  @@index([agentId])
}

model ValueStreamHitlGate {
  id                       String          @id @default(cuid())
  teamId                   String
  team                     ValueStreamTeam @relation(fields: [teamId], references: [id])
  triggerPoint             String // phase-transition|before-tool|after-evaluation|on-error
  condition                Json? // JSON expression evaluating context
  requiredRole             String // PlatformRole code (e.g., "HR-500", "HR-000")
  escalationTimeoutMinutes Int             @default(30)
  escalationPath           String[]        @default([])
  channels                 String[]        @default([]) // in-app|slack|email|sms
  emergencyBypass          Boolean         @default(false)
  bpmnGatewayId            String? // Link to EaElement (bpmn_gateway)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  @@index([teamId])
}

// ─── Discovery Connections ─────────────────────────────────────────────────────
// Connects discovered infrastructure entities (e.g. gateways) to their management
// APIs.  When a gateway is discovered, the user can configure a connection with
// credentials.  On subsequent discovery sweeps, collectors read these connections
// from the DB and use them to pull rich topology data.

model DiscoveryConnection {
  id                String            @id @default(cuid())
  connectionKey     String            @unique // e.g. "unifi:192.168.0.1"
  name              String // human label
  collectorType     String // "unifi" | future: "meraki", "fortigate", ...
  status            String            @default("unconfigured") // unconfigured | active | auth_failed | unreachable
  endpointUrl       String // e.g. "https://192.168.0.1"
  encryptedApiKey   String? // AES-256-GCM encrypted via credential-crypto
  configuration     Json              @default("{}") // collector-specific config (site, discoverClients, etc.)
  lastTestedAt      DateTime?
  lastTestStatus    String? // ok | auth_failed | unreachable | tls_error
  lastTestMessage   String?
  gatewayEntityId   String? // FK to the InventoryEntity that triggered this connection
  gatewayEntity     InventoryEntity?  @relation("DiscoveryConnectionGateway", fields: [gatewayEntityId], references: [id])
  inventoryEntities InventoryEntity[] @relation("DiscoveredViaConnection")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([collectorType])
  @@index([status])
}

// ---- Collaborative Work Queue (EP-CWQ-001) ----

model WorkQueue {
  id               String           @id @default(cuid())
  queueId          String           @unique @default(cuid())
  name             String
  queueType        String // team | personal | triage | escalation
  teamId           String?
  team             ValueStreamTeam? @relation(fields: [teamId], references: [id])
  routingPolicy    Json
  slaMinutes       Json?
  isActive         Boolean          @default(true)
  portfolioId      String?
  portfolio        Portfolio?       @relation(fields: [portfolioId], references: [id])
  digitalProductId String?
  digitalProduct   DigitalProduct?  @relation(fields: [digitalProductId], references: [id])
  items            WorkItem[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([teamId])
  @@index([portfolioId])
  @@index([queueType, isActive])
}

model WorkItem {
  id                String            @id @default(cuid())
  itemId            String            @unique @default(cuid())
  sourceType        String
  sourceId          String?
  title             String
  description       String            @db.Text
  urgency           String            @default("routine")
  effortClass       String            @default("medium")
  workerConstraint  Json
  teamId            String?
  team              ValueStreamTeam?  @relation(fields: [teamId], references: [id])
  queueId           String
  queue             WorkQueue         @relation(fields: [queueId], references: [id])
  status            String            @default("queued")
  assignedToType    String?
  assignedToUserId  String?
  assignedToUser    User?             @relation("WorkItemAssignee", fields: [assignedToUserId], references: [id])
  assignedToAgentId String?
  assignedToAgent   Agent?            @relation("WorkItemAgent", fields: [assignedToAgentId], references: [id])
  assignedThreadId  String?
  claimedAt         DateTime?
  dueAt             DateTime?
  calendarEventId   String?
  calendarEvent     CalendarEvent?    @relation(fields: [calendarEventId], references: [id])
  evidence          Json?
  parentItemId      String?
  parentItem        WorkItem?         @relation("WorkItemHierarchy", fields: [parentItemId], references: [id])
  childItems        WorkItem[]        @relation("WorkItemHierarchy")
  a2aTaskId         String?
  messages          WorkItemMessage[]
  routingDecision   Json?
  completedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([queueId, status])
  @@index([assignedToUserId, status])
  @@index([assignedToAgentId, status])
  @@index([teamId, status])
  @@index([parentItemId])
  @@index([sourceType, sourceId])
  @@index([urgency, status])
  @@index([dueAt])
}

model WorkItemMessage {
  id                String    @id @default(cuid())
  messageId         String    @unique @default(cuid())
  workItemId        String
  workItem          WorkItem  @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  senderType        String
  senderUserId      String?
  senderAgentId     String?
  messageType       String
  body              String    @db.Text
  structuredPayload Json?
  channel           String    @default("in-app")
  deliveredAt       DateTime?
  readAt            DateTime?
  respondedAt       DateTime?
  response          Json?
  createdAt         DateTime  @default(now())

  @@index([workItemId, createdAt])
  @@index([senderUserId])
}

model WorkSchedule {
  id                String   @id @default(cuid())
  workerType        String
  userId            String?  @unique
  user              User?    @relation(fields: [userId], references: [id])
  agentId           String?  @unique
  agent             Agent?   @relation("WorkScheduleAgent", fields: [agentId], references: [id])
  timezone          String   @default("UTC")
  workingHours      Json
  maxConcurrent     Int      @default(5)
  autoAccept        Boolean  @default(false)
  notificationPrefs Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── Prompt Templates ─────────────────────────────────────────────────────────
// Editable AI coworker instructions. Source of truth: prompts/*.prompt.md files.
// Seeded on deploy, overridable at runtime via Admin > Prompts.

model PromptTemplate {
  id            String   @id @default(cuid())
  category      String // platform-identity | platform-preamble | route-persona | build-phase | specialist | reviewer | context
  slug          String // filename stem (e.g. "portfolio-advisor")
  name          String // human-readable display name
  description   String? // what this prompt does
  content       String // the markdown body (below YAML frontmatter)
  contentFormat String   @default("markdown") // markdown | handlebars
  composesFrom  String[] @default([]) // category/slug refs for {{include:...}} resolution
  variables     Json? // declared template variables [{name, required}]
  metadata      Json? // all other frontmatter (IT4IT, Scott Page, sensitivity)
  isOverridden  Boolean  @default(false) // true when admin has edited from seed default
  enabled       Boolean  @default(true)
  version       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  updatedBy     String?

  revisions PromptRevision[]

  @@unique([category, slug])
  @@index([category])
}

model PromptRevision {
  id           String   @id @default(cuid())
  templateId   String
  version      Int
  content      String // snapshot of content at this version
  metadata     Json? // snapshot of metadata
  changeReason String?
  changedBy    String?
  createdAt    DateTime @default(now())

  template PromptTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId])
}

// ─── Deliberation Pattern Framework ────────────────────────────────────────────
// Reusable multi-agent quality patterns (review, debate, ...) executed over the
// existing TaskRun/TaskNode/TaskNodeEdge substrate.
//
// Spec: docs/superpowers/specs/2026-04-21-deliberation-pattern-framework-design.md
// Plan: docs/superpowers/plans/2026-04-22-deliberation-pattern-framework-v1.md
//
// Canonical enum values for the String columns below are documented inline and
// live in TypeScript (see apps/web/lib/deliberation/types.ts — arriving Task 3)
// and in the MCP tool enums. Hyphenated values per CLAUDE.md § "Strongly-Typed
// String Enums — MANDATORY COMPLIANCE".

model DeliberationPattern {
  id                    String   @id @default(cuid())
  slug                  String   @unique // e.g. "review", "debate"
  name                  String
  purpose               String   @db.Text
  defaultRoles          Json // Array<{ roleId, count, required }>
  topologyTemplate      Json // branch + convergence spec consumed by task-graph builder
  activationPolicyHints Json // { stageDefaults, riskEscalation, explicitTriggers } — hints, not authoritative
  evidenceRequirements  Json // { retrievalRequired, admissibleSourceTypes, freshness, conflictReconciliationRequired }
  outputContract        Json // shape of the DeliberationOutcome produced
  providerStrategyHints Json // preferred diversity mode and strategy profile
  sourceFile            String? // path to the seed file under deliberation/
  status                String   @default("active") // "active" | "deprecated" | "draft"
  isOverridden          Boolean  @default(false) // admin edited at runtime — seeder will skip
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  runs DeliberationRun[]

  @@index([status])
}

model DeliberationRoleProfile {
  id                       String   @id @default(cuid())
  roleId                   String   @unique // slug: "author" | "reviewer" | "skeptic" | "adjudicator" | "debater" | ...
  roleName                 String
  personaGuidance          String   @db.Text // portable persona prompt ({{include:...}} composition allowed)
  allowedNodeTypes         String[] @default([]) // which TaskNode.nodeType values this role can occupy
  sameModelPersonaAllowed  Boolean  @default(true)
  preferProviderDiversity  Boolean  @default(false)
  requireProviderDiversity Boolean  @default(false)
  evidenceStrictness       String   @default("standard") // "lenient" | "standard" | "strict"
  sourceFile               String? // path to the seed file for this persona
  isOverridden             Boolean  @default(false) // admin edited at runtime — seeder will skip
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([evidenceStrictness])
}

model DeliberationRun {
  id                 String    @id @default(cuid())
  taskRunId          String // FK to TaskRun.id — deliberation always parented to a task run
  patternId          String // FK to DeliberationPattern.id
  artifactType       String // "spec" | "plan" | "code-change" | "architecture-decision" | "policy" | "research-question"
  triggerSource      String // "stage" | "risk" | "explicit" | "combined"
  adjudicationMode   String // "synthesis" | "majority-vote" | "unanimous" | "no-consensus-ok"
  activatedRiskLevel String? // "low" | "medium" | "high" | "critical"
  diversityMode      String // "single-model-multi-persona" | "multi-model-same-provider" | "multi-provider-heterogeneous"
  strategyProfile    String // "economy" | "balanced" | "high-assurance" | "document-authority"
  consensusState     String    @default("pending") // "consensus" | "partial-consensus" | "no-consensus" | "insufficient-evidence" | "pending"
  maxBranches        Int       @default(4)
  budgetUsd          Float?
  metadata           Json? // free-form run metadata: degradation notes, budget-halted flag, etc.
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  taskRun         TaskRun                @relation(fields: [taskRunId], references: [id], onDelete: Cascade)
  pattern         DeliberationPattern    @relation(fields: [patternId], references: [id])
  outcome         DeliberationOutcome?
  issueSets       DeliberationIssueSet[]
  claims          ClaimRecord[]
  evidenceBundles EvidenceBundle[]
  branchNodes     TaskNode[]             @relation("DeliberationRunBranchNodes")

  @@index([taskRunId])
  @@index([patternId])
  @@index([consensusState])
  @@index([artifactType, consensusState])
}

model DeliberationOutcome {
  id                   String   @id @default(cuid())
  deliberationRunId    String   @unique
  mergedRecommendation String   @db.Text
  rationaleSummary     String   @db.Text
  confidence           Float?
  consensusState       String // duplicate of DeliberationRun.consensusState for read-only snapshot at synthesis time
  evidenceQuality      String? // "source-backed" | "mixed" | "needs-more-evidence"
  unresolvedRisks      String[] @default([])
  diversityLabel       String? // UI-friendly summary, e.g. "Multi-provider review"
  branchRoster         Json? // [{ branchNodeId, role, status }] — prevents false-success blindness (spec § 13)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  deliberationRun DeliberationRun @relation(fields: [deliberationRunId], references: [id], onDelete: Cascade)

  @@index([consensusState])
}

model DeliberationIssueSet {
  id                String   @id @default(cuid())
  deliberationRunId String
  assertions        Json     @default("[]") // compact list of supported assertions
  objections        Json     @default("[]") // list of objections raised by branches
  rebuttals         Json     @default("[]") // rebuttals to objections
  adjudicationNotes String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deliberationRun DeliberationRun @relation(fields: [deliberationRunId], references: [id], onDelete: Cascade)

  @@index([deliberationRunId])
}

model ClaimRecord {
  id                  String   @id @default(cuid())
  deliberationRunId   String
  branchNodeId        String? // FK to TaskNode.id — the branch that made the claim (nullable for synthesis-level facts)
  claimText           String   @db.Text
  claimType           String // "assertion" | "objection" | "rebuttal" | "synthesis-fact" | "synthesis-inference"
  status              String   @default("unresolved") // "supported" | "contested" | "unresolved" | "rejected"
  evidenceGrade       String // "A" | "B" | "C" | "D"
  confidence          Float?
  supportingSourceIds String[] @default([]) // EvidenceSource.id references supporting the claim
  opposingSourceIds   String[] @default([]) // EvidenceSource.id references opposing the claim
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  deliberationRun DeliberationRun @relation(fields: [deliberationRunId], references: [id], onDelete: Cascade)
  branchNode      TaskNode?       @relation("ClaimRecordBranchNode", fields: [branchNodeId], references: [id])

  @@index([deliberationRunId, claimType])
  @@index([branchNodeId])
  @@index([status])
  @@index([evidenceGrade])
}

model EvidenceBundle {
  id                String   @id @default(cuid())
  deliberationRunId String
  taskNodeId        String? // nullable — bundle may be run-level or branch-level
  artifactRef       String? // identifier of the artifact under evaluation (free-form)
  retrievalContext  Json? // query string, retrieval tool, filters
  summary           String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deliberationRun DeliberationRun  @relation(fields: [deliberationRunId], references: [id], onDelete: Cascade)
  taskNode        TaskNode?        @relation("EvidenceBundleTaskNode", fields: [taskNodeId], references: [id])
  sources         EvidenceSource[]

  @@index([deliberationRunId])
  @@index([taskNodeId])
}

model EvidenceSource {
  id               String    @id @default(cuid())
  evidenceBundleId String
  sourceType       String // "code" | "spec" | "doc" | "paper" | "web" | "db-query" | "tool-output" | "runtime-state"
  locator          Json // structured locator (file+line, URL+ts, DOI+page, query+capturedAt, etc.)
  retrievedBy      String? // tool or provider used to retrieve
  excerpt          String?   @db.Text // normalized excerpt/fact text
  retrievedAt      DateTime? // retrieval timestamp (freshness tracking)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  evidenceBundle EvidenceBundle @relation(fields: [evidenceBundleId], references: [id], onDelete: Cascade)

  @@index([evidenceBundleId])
  @@index([sourceType])
}
