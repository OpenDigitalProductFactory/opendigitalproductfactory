FROM node:20-alpine
RUN corepack enable && corepack prepare pnpm@latest --activate
RUN apk add --no-cache git postgresql16-client curl
RUN git config --global user.email "sandbox@dpf.local" \
 && git config --global user.name "DPF Sandbox"
WORKDIR /workspace
# No secrets, no Docker socket
# Resource limits applied at container creation

# Keep container alive — coding agent executes commands via docker exec
CMD ["sleep", "infinity"]
